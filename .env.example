# Copy this file to .env and fill in real values before running the server.

# Port the server listens on (Railway/Render set this automatically in production)
PORT=4000

# Long random string used to sign admin login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated list of origins allowed to call this API from a browser.
# Include your live site and, while testing, your local dev address.
ALLOWED_ORIGINS=https://heartandsoulparrotrescue.com,https://www.heartandsoulparrotrescue.com,http://localhost:3000

# Path to the SQLite database file. On Railway, point this at a mounted volume,
# e.g. /data/rescue.db, so data survives deploys.
DATABASE_PATH=./data/rescue.db
