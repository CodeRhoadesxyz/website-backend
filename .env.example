# Copy this file to .env and fill in real values before running the server.

# Port the server listens on (Railway/Render set this automatically in production)
PORT=4000

# Long random string used to sign admin login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated list of origins allowed to call this API from a browser.
# Include your live site and, while testing, your local dev address.
ALLOWED_ORIGINS=https://heartandsoulparrotrescue.com,https://www.heartandsoulparrotrescue.com,http://localhost:3000

# Path to the SQLite database file. On Railway, point this at a mounted volume,
# e.g. /data/rescue.db, so data survives deploys.
DATABASE_PATH=./data/rescue.db

# --- Email (optional but needed for application/RSVP notifications and password reset) ---
# See README.md "Setting up email" for how to get these from Gmail or another provider.
# If left blank, the server runs fine — it just skips sending any emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=heartandsoulparrots@gmail.com
SMTP_PASS=your-16-character-app-password
EMAIL_FROM=heartandsoulparrots@gmail.com

# Where new-application and new-RSVP notification emails get sent. Usually
# the same inbox as SMTP_USER, but doesn't have to be.
ADMIN_NOTIFY_EMAIL=heartandsoulparrots@gmail.com

# The exact URL of your blog page (where the blog.js widget lives) — used to
# build the link inside password reset emails. Falls back to your first
# ALLOWED_ORIGINS entry + /blog.html if not set, but setting it explicitly
# is safer if that guess would be wrong.
BLOG_PAGE_URL=https://heartandsoulparrotrescue.com/blog.html

# --- File uploads ---
# Where uploaded bird/event/announcement photos are stored. On Railway, keep
# this on the same mounted volume as DATABASE_PATH so uploads survive
# deploys too — e.g. /data/uploads.
UPLOADS_PATH=./data/uploads

# --- Database tools (optional) ---
# Set this to the exact username of the one admin account that should have
# access to /superadmin — raw table browsing/editing, table flushing,
# backups, server restart, and a read-only query tool. Leave blank to
# disable /superadmin entirely (it'll return an error instead of exposing
# anything). This does NOT create that admin account — it just restricts
# an already-existing one from the Admin Access tab.
SUPER_ADMIN_USERNAME=dalton
