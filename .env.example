# Copy this file to .env and fill in real values before running the server.

# Port the server listens on (Railway/Render set this automatically in production)
PORT=4000

# Long random string used to sign admin login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated list of origins allowed to call this API from a browser.
# Include your live site and, while testing, your local dev address.
ALLOWED_ORIGINS=https://heartandsoulparrotrescue.com,https://www.heartandsoulparrotrescue.com,http://localhost:3000

# Path to the SQLite database file. On Railway, point this at a mounted volume,
# e.g. /data/rescue.db, so data survives deploys.
DATABASE_PATH=./data/rescue.db

# --- Email (Brevo, formerly Sendinblue) ---
# Get a key at https://app.brevo.com/settings/keys/api — free plan covers
# 300 emails/day (~9,000/month) permanently, no credit card required.
BREVO_API_KEY=

# "From" address and name emails are sent as. Brevo requires the sender
# address to be a verified sender (or on a verified domain) in your Brevo
# account — add/verify it under Senders & IP in the Brevo dashboard.
EMAIL_FROM=info@heartandsoulparrotrescue.com
EMAIL_FROM_NAME=Heart & Soul Parrot Rescue

# Base URL where the admin portal (this same backend's /admin folder) is
# publicly reachable, no trailing slash. Used to build password-reset links
# and the "review in admin portal" link in new-application notifications.
# e.g. https://api.heartandsoulparrotrescue.com
ADMIN_BASE_URL=

# Base URL of the public-facing site (where blog users' reset-password page
# lives), no trailing slash. e.g. https://heartandsoulparrotrescue.com
SITE_BASE_URL=

# Comma-separated emails to notify when a new application comes in. If left
# blank, every admin with an email on file gets notified instead.
APPLICATION_NOTIFICATION_EMAILS=
